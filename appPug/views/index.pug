doctype html
html
  head
    meta(charset="UTF-8")
    title PUG

    style.
      body {
        margin: 0;
        font-family: Arial;
        background: linear-gradient(135deg, #dcedc8, #f5f5dc);
        animation: fadeIn 1s ease-in;
      }

      header {
        background: #aed581;
        padding: 15px;
        display: flex;
        justify-content: center;
        gap: 15px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
      }

      button {
        background: #fff;
        border: none;
        padding: 10px 15px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      button:hover {
        transform: scale(1.1);
        background: #c5e1a5;
      }

      .container {
        background: #fff;
        margin: 20px auto;
        padding: 20px;
        max-width: 800px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        animation: slideUp 0.8s ease;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes slideUp {
        from {
          transform: translateY(30px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

  body
    header
      button(onclick="goTo('/')") Pug
      button(onclick="goTo('/app')") App
      button(onclick="goTo('/app/resumo')") Resumo

    .container
      h1 O que é Pug 🐶
      p Pug é uma template engine que usa indentação no lugar de HTML tradicional.

    .container
      h2 Vantagens do Pug 🐶
      ul
        each item in lista
          li= item

    script.
      function goTo(r){window.location.href=r}